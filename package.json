{
  "name": "bus-buddy-monorepo",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "start": "npm run start --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "prisma:generate": "npx prisma generate --config backend/prisma.config.ts",
    "prisma:push": "npx prisma db push --config backend/prisma.config.ts",
    "prisma:migrate": "npx prisma migrate dev --config backend/prisma.config.ts"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "typescript": "^5.0.0"
  }
}
