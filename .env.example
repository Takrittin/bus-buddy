# BusBuddy environment template
#
# Copy the backend values into `backend/.env`.
# Copy the frontend values into `frontend/.env.local`.
# Do not put real secrets in this file.

# ---------------------------------------------------------------------------
# Backend
# ---------------------------------------------------------------------------

# PostgreSQL connection used by Prisma and backend services.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/busbuddy-db"

# NestJS API port.
PORT=3001

# Public frontend URL used for payment redirect links.
WEB_URL="http://localhost:3000"

# Google AI Studio / Gemini configuration.
# Leave GOOGLE_AI_API_KEY empty if you do not want AI features locally.
GOOGLE_AI_API_KEY=""
GOOGLE_AI_MODEL="gemini-2.5-flash"

# Stripe payment configuration.
# Required only for Premium checkout/payment features.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PREMIUM_CURRENCY="thb"

# Optional Stripe Price IDs.
# If omitted, the backend creates inline Stripe prices from the THB amounts below.
STRIPE_PREMIUM_PRICE_ID=""
STRIPE_TOURIST_WEEKLY_PRICE_ID=""

# Fallback inline prices when Stripe Price IDs are not provided.
PREMIUM_MONTHLY_PRICE_THB="99"
PREMIUM_WEEKLY_PRICE_THB="39"

# ---------------------------------------------------------------------------
# Frontend
# ---------------------------------------------------------------------------

# Backend API URL used by the Next.js frontend.
NEXT_PUBLIC_API_URL="http://localhost:3001"

# Longdo Map API key for map rendering and route calculation.
NEXT_PUBLIC_LONGDOMAP_KEY=""
